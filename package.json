{
  "name": "@whyun/tv-tools",
  "version": "0.1.4",
  "description": "TypeScript utilities for decoding TVBox JSON payloads",
  "license": "MIT",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/whyun-pages/tv-tools.git"
  },
  "scripts": {
    "clean": "rimraf dist coverage",
    "build:cjs": "rimraf dist/cjs && tsc --project tsconfig.build-cjs.json",
    "build:esm": "rimraf dist/esm && tsc --project tsconfig.build-esm.json",
    "build": "pnpm run clean && pnpm run build:cjs && pnpm run build:esm",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "pretest": "node -e \"require('node:fs').mkdirSync('coverage/.tmp', { recursive: true })\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest:ci": "node -e \"require('node:fs').mkdirSync('coverage/.tmp', { recursive: true })\"",
    "test:ci": "vitest run --coverage --reporter=default --reporter=junit"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "prettier": "^3.8.2",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
